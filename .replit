modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["google-calendar:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 4173
externalPort = 5173

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 8083
externalPort = 5000

[[ports]]
localPort = 23099
externalPort = 3000

[[ports]]
localPort = 23100
externalPort = 3002

[[ports]]
localPort = 23101
externalPort = 4200

[[ports]]
localPort = 24296
externalPort = 6000

[userenv]

[userenv.production]

[userenv.shared]
VITE_CLERK_PUBLISHABLE_KEY = "pk_test_ZmFzdC1waG9lbml4LTkuY2xlcmsuYWNjb3VudHMuZGV2JA"
